"""
Gerador de Prova OMR - Versão que gera HTML para impressão
(Como o navegador faz o PDF melhor que qualquer biblioteca)
"""

import os
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Any
import webbrowser

class GeradorProvaOMR:
    """Gera prova HTML que o usuário pode imprimir/salvar como PDF"""
    
    def __init__(self, output_dir="output"):
        self.output_dir = Path(output_dir)
        self.output_dir.mkdir(parents=True, exist_ok=True)
    
    def gerar_html(self, dados: Dict[str, Any]) -> str:
        """Gera o HTML completo da prova"""
        
        nome_escola = dados.get('nome_escola', 'ESCOLA MUNICIPAL')
        disciplina = dados.get('disciplina', 'Matemática')
        ano = dados.get('ano', '5º Ano')
        turma = dados.get('turma', 'Turma A')
        codigo_prova = dados.get('codigo_prova', f'PROV_{datetime.now().strftime("%Y%m%d%H%M%S")}')
        questoes = dados.get('questoes', [])
        
        # Construir questões
        questoes_html = ""
        for i, q in enumerate(questoes, 1):
            enunciado = q.get('enunciado', f'Questão {i}')
            recurso = q.get('recurso', None)
            alternativas = q.get('alternativas', ['A', 'B', 'C', 'D'])
            
            questoes_html += f"""
            <div class="questao">
                <div class="questao-header">
                    <span class="questao-numero">{i})</span>
                    <span class="questao-enunciado">{enunciado}</span>
                </div>
            """
            
            if recurso:
                questoes_html += f"""
                <div class="recurso">
                    <div class="recurso-texto">{recurso}</div>
                </div>
                """
            
            questoes_html += f"""
                <div class="alternativas">
            """
            
            letras = ['A', 'B', 'C', 'D']
            for j, alt in enumerate(alternativas[:4]):
                questoes_html += f"""
                    <div class="alternativa">
                        <span class="alternativa-letra">{letras[j]})</span>
                        <span class="alternativa-texto">{alt}</span>
                    </div>
                """
            
            questoes_html += f"""
                </div>
            </div>
            """
        
        num_questoes = len(questoes) if questoes else 20
        
        # Grade cabeçalho
        grade_cabecalho = '<th></th>'
        for q in range(1, num_questoes + 1):
            grade_cabecalho += f'<th>{q}</th>'
        
        # Grade corpo
        grade_corpo = ""
        for letra in ['A', 'B', 'C', 'D']:
            linha = f'<tr><td class="alternativa-letra">{letra}</td>'
            for q in range(num_questoes):
                linha += '<td><div class="circulo"></div></td>'
            linha += '</tr>'
            grade_corpo += linha
        
        html = f'''<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>LADOS - Prova</title>
    <style>
        * {{ margin: 0; padding: 0; box-sizing: border-box; }}
        body {{ font-family: Arial, sans-serif; background: #e0e0e0; padding: 20px; }}
        .pagina {{
            width: 210mm;
            min-height: 297mm;
            background: white;
            margin: 0 auto;
            padding: 15mm 15mm 0 15mm;
            position: relative;
            font-size: 11pt;
            line-height: 1.2;
        }}
        /* PONTOS DE REFERÊNCIA OMR - PRETOS NOS 4 CANTOS */
        .omr-mark {{
            position: absolute;
            width: 5mm;
            height: 5mm;
            background: black;
            z-index: 100;
        }}
        .omr-topo-esq {{ top: 0; left: 0; }}
        .omr-topo-dir {{ top: 0; right: 0; }}
        .omr-baixo-esq {{ bottom: 0; left: 0; }}
        .omr-baixo-dir {{ bottom: 0; right: 0; }}
        
        .nome-escola {{ text-align: center; font-weight: bold; text-transform: uppercase; margin-bottom: 6px; }}
        .subtitulo-prova {{ text-align: center; margin-bottom: 12px; }}
        .linha-nome {{ display: flex; align-items: baseline; margin-bottom: 10px; }}
        .label-nome {{ font-weight: bold; width: 50px; }}
        .linha-continua-nome {{ flex: 1; border-bottom: 1px solid black; margin-left: 5px; }}
        .linha-info {{ display: flex; justify-content: space-between; margin-bottom: 12px; gap: 20px; }}
        .campo-professor {{ flex: 3; }}
        .campo-data {{ flex: 2; }}
        .campo-conceito {{ flex: 2; }}
        .label-bold {{ font-weight: bold; margin-right: 5px; }}
        .linha-continua {{ border-bottom: 1px solid black; display: inline-block; min-width: 120px; margin-left: 5px; }}
        .linha-continua-data {{ border-bottom: 1px solid black; display: inline-block; min-width: 80px; margin-left: 5px; }}
        .linha-separadora {{ border-top: 1px solid #ccc; margin: 8px 0 10px 0; }}
        
        .container-instrucoes-qrcode {{ display: flex; gap: 20px; margin: 8px 0 12px 0; }}
        .coluna-instrucoes {{ flex: 75%; }}
        .coluna-qrcode {{ flex: 25%; display: flex; justify-content: center; align-items: center; }}
        .qrcode-placeholder {{ width: 88px; height: 88px; background: #000; display: flex; align-items: center; justify-content: center; text-align: center; font-size: 8px; color: white; }}
        .instrucoes h4 {{ margin-bottom: 6px; }}
        .instrucoes ol {{ padding-left: 25px; }}
        .instrucoes li {{ margin-bottom: 2px; font-size: 10pt; }}
        
        .grade-container {{ margin: 12px 0 20px 0; }}
        .grade-titulo {{ font-weight: bold; text-align: center; margin-bottom: 8px; }}
        .grade-tabela {{ width: 100%; border-collapse: collapse; text-align: center; font-size: 9pt; }}
        .grade-tabela th, .grade-tabela td {{ border: 1px solid #ccc; padding: 5px 2px; }}
        .grade-tabela th {{ background: #f5f5f5; }}
        .grade-tabela th:first-child, .grade-tabela td:first-child {{ width: 30px; background: #f9f9f9; }}
        .circulo {{ width: 16px; height: 16px; border-radius: 50%; border: 1px solid black; display: inline-block; background: white; }}
        
        .questoes-container {{ margin-top: 15px; }}
        .questao {{ margin-bottom: 20px; page-break-inside: avoid; }}
        .questao-header {{ margin-bottom: 5px; }}
        .questao-numero {{ font-weight: bold; margin-right: 8px; }}
        .questao-enunciado {{ display: inline; }}
        .recurso {{ margin: 6px 0; text-align: center; padding: 0 2cm; }}
        .recurso-texto {{ text-align: justify; font-size: 10pt; }}
        .alternativas {{ margin-top: 5px; margin-left: 30px; }}
        .alternativa {{ margin-bottom: 3px; }}
        .alternativa-letra {{ font-weight: bold; width: 22px; display: inline-block; }}
        .alternativa-texto {{ display: inline; }}
        
        .rodape {{
            position: absolute;
            bottom: 10mm;
            left: 15mm;
            right: 15mm;
            text-align: center;
            font-size: 8pt;
            color: #666;
            border-top: 1px solid #ccc;
            padding-top: 5px;
        }}
        .rodape-codigo {{ font-family: monospace; }}
        
        @media print {{
            body {{ background: white; padding: 0; }}
            .pagina {{ box-shadow: none; margin: 0; }}
        }}
    </style>
</head>
<body>
    <div class="pagina">
        <div class="omr-mark omr-topo-esq"></div>
        <div class="omr-mark omr-topo-dir"></div>
        <div class="omr-mark omr-baixo-esq"></div>
        <div class="omr-mark omr-baixo-dir"></div>
        
        <div class="nome-escola">{nome_escola}</div>
        <div class="subtitulo-prova">Prova de {disciplina} - {ano} - {turma}</div>
        
        <div class="linha-nome"><span class="label-nome">Nome:</span><div class="linha-continua-nome"></div></div>
        
        <div class="linha-info">
            <div class="campo-professor"><span class="label-bold">Professor(a):</span><span class="linha-continua"></span></div>
            <div class="campo-data"><span class="label-bold">Data:</span><span class="linha-continua-data"></span></div>
            <div class="campo-conceito"><span class="label-bold">Conceito/Nota:</span><span class="linha-continua-data"></span></div>
        </div>
        
        <div class="linha-separadora"></div>
        
        <div class="container-instrucoes-qrcode">
            <div class="coluna-instrucoes">
                <div class="instrucoes">
                    <h4>INSTRUÇÕES:</h4>
                    <ol><li>Leia cada questão com atenção.</li><li>Marque apenas uma alternativa.</li><li>Questões com duas alternativas marcadas serão consideradas erradas.</li><li>Ao preencher a grade, pinte o círculo completamente.</li><li>Sempre use caneta azul ou preta.</li></ol>
                </div>
            </div>
            <div class="coluna-qrcode">
                <div class="qrcode-placeholder">QR CODE<br>{codigo_prova}</div>
            </div>
        </div>
        
        <div class="grade-container">
            <div class="grade-titulo">GRADE DE RESPOSTAS</div>
            <table class="grade-tabela">
                <thead><tr>{grade_cabecalho}</tr></thead>
                <tbody>{grade_corpo}</tbody>
            </table>
        </div>
        
        <div class="questoes-container">
            {questoes_html}
        </div>
        
        <div class="rodape">
            <div class="rodape-codigo">{codigo_prova}</div>
            <div><strong>SISTEMA LADOS</strong> - 2026. Todos os Direitos Reservados.</div>
        </div>
    </div>
</body>
</html>'''
        
        return html
    
    def gerar_prova_para_impressao(self, dados: Dict[str, Any]) -> Path:
        """Gera arquivo HTML e abre para impressão"""
        
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        html_path = self.output_dir / f"prova_{timestamp}.html"
        
        # Salvar HTML
        html_content = self.gerar_html(dados)
        with open(html_path, 'w', encoding='utf-8') as f:
            f.write(html_content)
        
        # Abrir no navegador para impressão
        webbrowser.open(f"file://{html_path.absolute()}")
        
        return html_path


# Função principal compatível com a página
def gerar_prova(dados: Dict[str, Any]) -> Path:
    """Gera prova e retorna o caminho do arquivo HTML (não PDF)"""
    gerador = GeradorProvaOMR()
    return gerador.gerar_prova_para_impressao(dados)
